# LEGAL-CHAIN — Environment Configuration
# Copy to .env and fill in values.

# ── Chain Node ──
CHAIN_SPEC=dev
NODE_NAME=legal-chain-dev-01
BASE_PATH=./data/node
RPC_PORT=9944
P2P_PORT=30333
PROMETHEUS_PORT=9615

# ── Validator Keys ──
# Generate via: legal-chain-node key generate --scheme Sr25519
# AURA_SECRET_SEED=
# GRANDPA_SECRET_SEED=

# ── Indexer ──
DATABASE_URL=postgres://legal:legal@localhost:5432/legal_chain_indexer
INDEXER_START_BLOCK=0
INDEXER_RPC_URL=ws://127.0.0.1:9944

# ── Explorer API ──
EXPLORER_PORT=4000
EXPLORER_DB_URL=postgres://legal:legal@localhost:5432/legal_chain_indexer

# ── Proof Service ──
PROOF_SERVICE_PORT=4100
PROOF_CHAIN_RPC=ws://127.0.0.1:9944

# ── Off-chain Storage (dev: local filesystem) ──
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./data/offchain-storage
# STORAGE_S3_BUCKET=
# STORAGE_S3_REGION=
# STORAGE_ENCRYPTION_KEY=
